        }
      ],
      "body": "fieldNormalized f =\n  (f.len <= (`FLs : [IW])) /\\\n  and [ (i >= f.len) ==> ((f.buf @ i) == 0)\n      | i <- ([0 .. FLs - 1] : [FLs][IW]) ]",
