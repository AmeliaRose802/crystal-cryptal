      "name": "VaultUnavailableIsInternal",
      "params": [
        "activationResult"
      ],
      "body": "isActivationResult activationResult ==>\nenrollDevice True True AR_VaultUnavailable activationResult\n== ER_InternalError",
      "doc": [
