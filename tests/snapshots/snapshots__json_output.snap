  {
    "Section": {
      "level": 2,
      "title": "5. Security properties (P1–P22)",
      "doc": []
    }
  },
  {
    "Section": {
      "level": 3,
      "title": "Category A: Key Lifecycle Safety",
      "doc": []
    }
  },
  {
    "Property": {
      "label": "P1",
      "name": "KeyMonotonicity",
      "params": [
        "fleetEnabled",
        "validMetadata",
        "authResult",
        "keyAlreadyActive"
      ],
      "body": "isAuthResult authResult ==>\nkeyAlreadyActive ==>\nenrollDevice fleetEnabled validMetadata authResult AC_AlreadyActive\n!= ER_Succeeded",
      "doc": [
        "P1: Key Monotonicity. Once a key is active, any subsequent activation",
        "attempt returns AlreadyActive. We model \"the activation outcome when the",
        "key is already active\" as a function of the activation oracle; the spec",
        "states this as an invariant on activationResult, which we express as:",
        "for any inputs, if the system reports the key is active then enrollDevice",
        "can never return Succeeded."
      ],
      "proof_status": null
    }
  },
  {
    "Property": {
      "label": "P2",
      "name": "ActivePreventsProvisioning",
      "params": [
        "fleetEnabled",
        "validRequest",
        "vaultResult"
      ],
      "body": "isKeyVaultResult vaultResult ==>\nfleetEnabled ==>\nvalidRequest ==>\nvaultResult == KV_Ok ==>\nprovisionKey fleetEnabled validRequest vaultResult True\n== PR_Unauthorized",
      "doc": [
        "P2: Active prevents provisioning."
      ],
      "proof_status": null
    }
  },
  {
    "Property": {
      "label": "P3",
      "name": "KeyIdHiddenUntilActive",
      "params": [
        "fleetEnabled",
        "hasKey",
        "keyId"
      ],
      "body": "(getStatus fleetEnabled hasKey False keyId).keyId == none",
      "doc": [
        "P3: Key ID hidden until active."
      ],
      "proof_status": null
    }
  },
  {
    "Property": {
      "label": "P4",
      "name": "KeyIdRevealedWhenActive",
      "params": [
        "fleetEnabled",
        "hasKey",
        "keyId"
      ],
      "body": "(getStatus fleetEnabled hasKey True keyId).keyId == some keyId",
      "doc": [
        "P4: Key ID revealed when active."
      ],
      "proof_status": null
    }
  },
  {
    "Property": {
      "label": "P5",
      "name": "DisabledRejectsAll",
      "params": [
        "validRequest",
        "vaultResult",
        "validMetadata",
        "authResult",
        "activationResult",
        "keyIsActive"
      ],
      "body": "isKeyVaultResult vaultResult ==>\nisAuthResult authResult ==>\nisActivationResult activationResult ==>\n(provisionKey False validRequest vaultResult keyIsActive == PR_Disabled)\n&& (enrollDevice False validMetadata authResult activationResult\n== ER_Disabled)",
      "doc": [
        "P5: Disabled rejects all."
      ],
      "proof_status": null
    }
  },
