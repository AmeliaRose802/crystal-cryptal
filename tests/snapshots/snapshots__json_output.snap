    }
  },
  {
    "Property": {
      "label": "P22",
      "name": "ActivationIoFailureIsInternal",
      "params": [
        "activationResult"
      ],
      "body": "isActivationResult activationResult ==>\n(activationResult != AC_Success) ==>\n(activationResult != AC_AlreadyActive) ==>\nenrollDevice True True AR_Authenticated activationResult\n== ER_InternalError",
      "doc": [
        "P22: Activation I/O failure is InternalError. An activation result that is",
        "neither Success nor AlreadyActive (i.e. an I/O failure) must yield",
        "InternalError when authentication succeeded."
      ],
      "proof_status": null
    }
