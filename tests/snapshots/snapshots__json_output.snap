    }
  },
  {
    "Property": {
      "label": "P17",
      "name": "TimestampAtBoundaryValid",
      "params": [
        "(requestTs : Timestamp)",
        "(window : Window)"
      ],
      "body": "// Avoid 64-bit overflow when constructing currentTime.\n(requestTs <= (~ zero) - window) ==>\nisValidRequestDate requestTs (requestTs + window) window == True",
      "doc": [
