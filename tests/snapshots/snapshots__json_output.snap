    }
  },
  {
    "Property": {
      "label": "P15",
      "name": "CanProvisionWhenReady",
      "params": [],
      "body": "provisionKey True True KV_Ok False == PR_Succeeded",
      "doc": [
        "P15: Can provision when ready."
      ],
