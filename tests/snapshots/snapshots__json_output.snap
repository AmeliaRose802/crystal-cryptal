      "branches": [
        {
          "condition": null,
          "result": "requestNormalized r =\n  fieldNormalized r.method /\\\n  fieldNormalized r.path /\\\n  fieldNormalized r.body /\\\n  and [ fieldNormalized h.name /\\ fieldNormalized h.value\n      | h <- r.hdrs ]"
        }
      ],
      "body": "requestNormalized r =\n  fieldNormalized r.method /\\\n  fieldNormalized r.path /\\\n  fieldNormalized r.body /\\\n  and [ fieldNormalized h.name /\\ fieldNormalized h.value\n      | h <- r.hdrs ]",
      "doc": [],
