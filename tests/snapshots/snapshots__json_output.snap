      "doc": [
        "P9: Wrong signature fails."
      ],
      "proof_status": null
    }
  },
  {
    "Property": {
      "label": "P10",
      "name": "MissingMetadataFails",
      "params": [
        "fleetEnabled",
        "authResult",
        "activationResult"
      ],
      "body": "fleetEnabled ==>\nisAuthResult authResult ==>\nisActivationResult activationResult ==>\nenrollDevice fleetEnabled False authResult activationResult\n== ER_Unauthorized",
      "doc": [
        "P10: Missing metadata fails (when the fleet is enabled).",
        "Note: when the fleet is disabled, enrollDevice short-circuits to",
        "ER_Disabled before the metadata check, so we restrict this property",
        "to the fleetEnabled case. The disabled case is covered by P5."
      ],
      "proof_status": null
