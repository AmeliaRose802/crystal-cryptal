      "branches": [
        {
          "condition": null,
          "result": "isValidRequestDate requestTs currentTime windowSeconds =\n  (requestTs <= currentTime)\n  && ((currentTime - requestTs) <= windowSeconds)"
        }
      ],
      "body": "isValidRequestDate requestTs currentTime windowSeconds =\n  (requestTs <= currentTime)\n  && ((currentTime - requestTs) <= windowSeconds)",
      "doc": [],
      "proof_status": null
    }
  },
  {
    "TypeAlias": {
      "name": "HmacKey",
      "width": "256",
      "doc": [
        "4.3.2 isValidSignature — modelled abstractly with an uninterpreted HMAC.",
        "The Cryptol-level model treats HMAC-SHA256 as an opaque function from",
        "(key, payload) to a 256-bit tag, and constantTimeEquals as `==`. The",
        "canonicalizePayload step is collapsed into the abstract request value",
        "because canonicalization is itself a pure function of the request."
      ]
    }
  },
  {
    "TypeAlias": {
      "name": "HmacTag",
      "width": "256",
      "doc": []
    }
  },
  {
    "TypeAlias": {
      "name": "Request",
      "width": "256",
      "doc": []
    }
  },
  {
    "Function": {
      "name": "hmacSha256",
      "signature": "HmacKey -> Request -> HmacTag",
      "branches": [
        {
          "condition": null,
          "result": "hmacSha256 k r = k ^ r ^ (r <<< 1)   // placeholder; specs only use equality"
        }
      ],
      "body": "hmacSha256 k r = k ^ r ^ (r <<< 1)   // placeholder; specs only use equality",
      "doc": [
        "Uninterpreted in proofs (SAW can treat this as a Cryptol primitive)."
      ],
      "proof_status": null
    }
  },
  {
    "Function": {
      "name": "isValidSignature",
      "signature": "HmacKey -> Request -> HmacTag -> Bit",
      "branches": [
        {
          "condition": null,
          "result": "isValidSignature key req providedSig =\n  hmacSha256 key req == providedSig"
        }
      ],
      "body": "isValidSignature key req providedSig =\n  hmacSha256 key req == providedSig",
      "doc": [],
      "proof_status": null
    }
  },
  {
    "Function": {
      "name": "enforceAccess",
      "signature": "AccessMode -> AccessDecision -> (Bit, Bit)",
      "branches": [
        {
          "condition": "mode == AM_Off",
          "result": "(True, False)"
        },
        {
          "condition": "mode == AM_Audit",
          "result": ""
        },
        {
          "condition": "mode == AM_Enforce",
          "result": ""
        },
        {
          "condition": "decision == AD_Deny",
          "result": "(False, True)"
        },
        {
          "condition": null,
          "result": "(True,  False))"
        },
        {
          "condition": null,
          "result": "(True, False)   // unreachable for well-formed modes"
        }
      ],
      "body": "enforceAccess mode decision =\n  if mode == AM_Off then (True, False)\n   | mode == AM_Audit then\n        (if decision == AD_Deny then (True, True) else (True, False))\n   | mode == AM_Enforce then\n        (if decision == AD_Allow  then (True,  False)\n          | decision == AD_Deny   then (False, True)\n         else                          (True,  False))\n  else (True, False)   // unreachable for well-formed modes",
      "doc": [],
      "proof_status": null
    }
  },
  {
    "Function": {
      "name": "getStatus",
      "signature": "Bit -> Bit -> Bit -> UUID -> EnrollmentStatus",
      "branches": [
        {
          "condition": null,
          "result": "getStatus fleetEnabled hasKey keyIsActive keyId =\n  { fleetMode = if fleetEnabled then FM_Enabled else FM_Disabled\n  , hasKey    = hasKey\n  , keyId     = if keyIsActive then some keyId else none\n  , isActive  = keyIsActive\n  }"
        }
      ],
      "body": "getStatus fleetEnabled hasKey keyIsActive keyId =\n  { fleetMode = if fleetEnabled then FM_Enabled else FM_Disabled\n  , hasKey    = hasKey\n  , keyId     = if keyIsActive then some keyId else none\n  , isActive  = keyIsActive\n  }",
      "doc": [],
