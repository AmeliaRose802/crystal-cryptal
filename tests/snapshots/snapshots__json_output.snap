    "Section": {
      "level": 2,
      "title": "4. Decision logic",
      "doc": []
    }
  },
  {
    "Function": {
      "name": "provisionKey",
      "signature": "Bit -> Bit -> KeyVaultResult -> Bit -> ProvisionResult",
      "branches": [
        {
          "condition": "~ fleetEnabled",
          "result": "PR_Disabled"
        },
        {
          "condition": "~ validRequest",
          "result": "PR_BadRequest"
        },
        {
          "condition": "vaultResult != KV_Ok",
          "result": "PR_InternalError"
        },
        {
          "condition": "keyIsActive",
          "result": "PR_Unauthorized"
        },
        {
          "condition": null,
          "result": "PR_Succeeded"
        }
      ],
      "body": "provisionKey fleetEnabled validRequest vaultResult keyIsActive =\n  if ~ fleetEnabled        then PR_Disabled\n   | ~ validRequest        then PR_BadRequest\n   | vaultResult != KV_Ok  then PR_InternalError\n   | keyIsActive           then PR_Unauthorized\n  else                          PR_Succeeded",
      "doc": [],
      "proof_status": null
    }
  },
  {
    "Function": {
      "name": "enrollDevice",
      "signature": "Bit -> Bit -> AuthResult -> ActivationResult -> EnrollmentResult",
      "branches": [
        {
          "condition": "~ fleetEnabled",
          "result": "ER_Disabled"
        },
        {
          "condition": "~ validMetadata",
          "result": "ER_Unauthorized"
        },
        {
          "condition": "authResult == AR_Authenticated",
          "result": ""
        },
        {
          "condition": "activationResult == AC_AlreadyActive",
          "result": "ER_Unauthorized"
        },
        {
          "condition": null,
          "result": "ER_InternalError)"
        },
        {
          "condition": "authResult == AR_VaultUnavailable",
          "result": "ER_InternalError"
        },
        {
          "condition": null,
          "result": "ER_Unauthorized"
        }
      ],
      "body": "enrollDevice fleetEnabled validMetadata authResult activationResult =\n  if ~ fleetEnabled                       then ER_Disabled\n   | ~ validMetadata                      then ER_Unauthorized\n   | authResult == AR_Authenticated       then\n        (if activationResult == AC_Success       then ER_Succeeded\n          | activationResult == AC_AlreadyActive then ER_Unauthorized\n         else                                         ER_InternalError)\n   | authResult == AR_VaultUnavailable    then ER_InternalError\n  else                                         ER_Unauthorized",
      "doc": [],
      "proof_status": null
    }
  },
  {
    "Function": {
      "name": "authenticate",
      "signature": "Bit -> Bit -> Bit -> Bit",
      "branches": [
        {
          "condition": null,
          "result": "authenticate dateValid signatureValid claimsValid =\n  dateValid && signatureValid && claimsValid"
        }
      ],
      "body": "authenticate dateValid signatureValid claimsValid =\n  dateValid && signatureValid && claimsValid",
      "doc": [],
      "proof_status": null
    }
  },
