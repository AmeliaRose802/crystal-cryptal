        "(window : Window)"
      ],
      "body": "(requestTs <= currentTime) ==>\n((currentTime - requestTs) > window) ==>\nisValidRequestDate requestTs currentTime window == False",
      "doc": [
        "P18: Timestamp beyond boundary is invalid."
      ],
      "proof_status": null
    }
  },
  {
